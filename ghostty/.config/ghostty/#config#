# ~/.config/ghostty/config
# Ghostty terminal emulator configuration
# https://ghostty.org/docs/config/reference

shell-integration = none

# ─────────────────────────────────────────────────────────────────────────────
# FONT
# ─────────────────────────────────────────────────────────────────────────────
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true

# ─────────────────────────────────────────────────────────────────────────────
# THEME
# ─────────────────────────────────────────────────────────────────────────────
#theme = Catppuccin Mocha
background = 4f4f4f


# ─────────────────────────────────────────────────────────────────────────────
# WINDOW
# ─────────────────────────────────────────────────────────────────────────────
window-padding-x = 8
window-padding-y = 8
# Initial window size in columns x rows
window-width = 90
window-height = 45
# WHY: Keeps padding color consistent with terminal background instead of theme color
window-padding-color = background
window-save-state = always
# WHY: Show native macOS scrollbar for buffer navigation
window-decoration = true
