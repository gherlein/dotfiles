#!/bin/bash
#
# gg - Git Gather: Pull and push all git repos in current directory
#
# Usage:
#   gg "commit message"     # Pull, commit changes, push for all repos
#   gg                      # Same, with default message "interim commit"
#   gg -s                   # Status only - show branch and changes for each repo
#
# Examples:
#   gg "update documentation"
#   gg "fix: resolve link issues"
#   gg -s
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the base directory
BASE_DIR="$(pwd)"
COMMIT_MSG="${1:-interim commit}"

# Print header
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}gg - Git Gather${NC}"
echo -e "${BLUE}Base directory: ${NC}$BASE_DIR"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo

# Status only mode
if [[ "$1" == "-s" || "$1" == "--status" ]]; then
    echo -e "${YELLOW}Status mode - showing repo status only${NC}"
    echo

    for dir in */; do
        dir="${dir%/}"  # Remove trailing slash

        if [[ -d "$dir/.git" ]]; then
            cd "$BASE_DIR/$dir"

            BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
            CHANGES=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
            AHEAD=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "?")
            BEHIND=$(git rev-list --count HEAD..@{u} 2>/dev/null || echo "?")

            if [[ "$CHANGES" -gt 0 ]]; then
                STATUS="${YELLOW}$CHANGES changes${NC}"
            else
                STATUS="${GREEN}clean${NC}"
            fi

            echo -e "${GREEN}$dir${NC} [${BLUE}$BRANCH${NC}] - $STATUS (↑$AHEAD ↓$BEHIND)"

            cd "$BASE_DIR"
        fi
    done

    exit 0
fi

# Find all git repos in current directory
REPOS=()
for dir in */; do
    dir="${dir%/}"  # Remove trailing slash
    if [[ -d "$dir/.git" ]]; then
        REPOS+=("$dir")
    fi
done

if [[ ${#REPOS[@]} -eq 0 ]]; then
    echo -e "${RED}No git repositories found in $BASE_DIR${NC}"
    exit 1
fi

echo -e "Found ${GREEN}${#REPOS[@]}${NC} git repositories:"
for repo in "${REPOS[@]}"; do
    echo "  - $repo"
done
echo

# Process each repo
for repo in "${REPOS[@]}"; do
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Processing: $repo${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    cd "$BASE_DIR/$repo"

    # Get current branch
    BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [[ -z "$BRANCH" ]]; then
        echo -e "${RED}  Could not determine branch, skipping${NC}"
        cd "$BASE_DIR"
        continue
    fi
    echo -e "  Branch: ${BLUE}$BRANCH${NC}"

    # Check for remote
    REMOTE=$(git remote 2>/dev/null | head -n1)
    if [[ -z "$REMOTE" ]]; then
        echo -e "${YELLOW}  No remote configured, skipping pull/push${NC}"
        cd "$BASE_DIR"
        continue
    fi

    # Pull latest changes
    echo -e "  ${YELLOW}Pulling...${NC}"
    if git pull --rebase 2>/dev/null; then
        echo -e "  ${GREEN}Pull successful${NC}"
    else
        echo -e "  ${YELLOW}Pull failed or nothing to pull${NC}"
    fi

    # Check if there are changes to commit
    if [[ -n $(git status --porcelain 2>/dev/null) ]]; then
        echo -e "  ${YELLOW}Adding changes...${NC}"
        git add -A

        echo -e "  ${YELLOW}Committing: $COMMIT_MSG${NC}"
        git commit -m "$COMMIT_MSG" || true

        echo -e "  ${YELLOW}Pushing to $REMOTE/$BRANCH...${NC}"
        if git push "$REMOTE" "$BRANCH" 2>/dev/null; then
            echo -e "  ${GREEN}Push successful${NC}"
        else
            echo -e "  ${RED}Push failed${NC}"
        fi
    else
        echo -e "  ${GREEN}No changes to commit${NC}"
        # Still push in case there are unpushed commits
        UNPUSHED=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "0")
        if [[ "$UNPUSHED" -gt 0 ]]; then
            echo -e "  ${YELLOW}Pushing $UNPUSHED unpushed commit(s)...${NC}"
            if git push "$REMOTE" "$BRANCH" 2>/dev/null; then
                echo -e "  ${GREEN}Push successful${NC}"
            else
                echo -e "  ${RED}Push failed${NC}"
            fi
        fi
    fi

    echo
    cd "$BASE_DIR"
done

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}Done!${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
