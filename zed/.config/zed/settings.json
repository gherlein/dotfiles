{
    "project_panel": {
        "dock": "left"
    },
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": []
    },
    "git_panel": {
        "dock": "left"
    },
    "window_decorations": "server",
    "soft_wrap": "editor_width",
    "assistant": {
        "always_allow_tool_actions": true,
        "default_model": {
            "provider": "copilot_chat",
            "model": "gpt-4o"
        },
        "version": "2"
    },
    "telemetry": {
        "diagnostics": true,
        "metrics": true
    },
    "show_inline_completions": false,
    "show_copilot_suggestions": false,
    "features": {
        "copilot": false
    },
    "autosave": "on_focus_change",
    "autosave_delay": 1500,
    "autosave_on_focus_change": true,
    "autosave_on_window_change": true,
    "autosave_on_build": true,
    "autosave_on_build_delay": 1500,
    "format_on_save": "on",
    "prettier": {
        "printWidth": 80,
        "tabWidth": 2,
        "useTabs": false,
        "semi": true,
        "singleQuote": true,
        "trailingComma": "all",
        "bracketSpacing": true,
        "jsxBracketSameLine": false,
        "arrowParens": "avoid",
        "proseWrap": "preserve",
        "endOfLine": "lf"
    },
    "linter": "eslint",
    "bracket_pairing": "always",
    "eslint": {
        "enabled": true,
        "autoFixOnSave": true,
        "autoFixOnFormat": true,
        "autoFixOnFormatDelay": 1500
    },
    "languages": {
        "C": {
            "format_on_save": "language_server",
            "tab_size": 2
        },
        "JSON": {
            "format_on_save": "language_server",
            "tab_size": 4
        },
        "JavaScript": {
            "code_actions_on_format": {
                "source.fixAll.eslint": true
            }
        },
        "TypeScript": {
            "code_actions_on_format": {
                "source.organizeImports": true,
                "source.fixAll.eslint": true
            }
        },
        "Python": {
            "format_on_save": "language_server",
            "tab_size": 4
        },
        "Markdown": {
            "format_on_save": "language_server",
            "tab_size": 2,
            "show_inline_completions": false
        },
        "HTML": {
            "format_on_save": "language_server",
            "tab_size": 2
        },
        "CSS": {
            "format_on_save": "language_server",
            "tab_size": 2
        },
        "go": {
            "format_on_save": "language_server",
            "tab_size": 2
        }
    },
    "ssh_connections": [
        {
            "host": "io",
            "projects": []
        },
        {
            "host": "io",
            "projects": [
                {
                    "paths": [
                        "/home/gherlein/src"
                    ]
                }
            ]
        }
    ],
    "base_keymap": "VSCode",
    "ui_font_size": 14,
    "buffer_font_size": 14.0,
    "buffer_font_family": "DejaVu Sans Mono",
    "buffer_font_weight": 500,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "One Dark"
    },
    "always_treat_brackets_as_autoclosed": true,
    "context_servers": {},
    "experimental.theme_overrides": {
        "background": "#2b2b2b",
        "editor.background": "#282828",
        "surface.background": "#2b2b2b",
        "elevated_surface.background": "#333333",
        "editor.gutter.background": "#282828",
        "text": "#f0f0f0",
        "editor.foreground": "#f0f0f0",
        "text.muted": "#b0b0b0"
    }
}
