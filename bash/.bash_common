# Shared environment — sourced by both .bash_profile and .bashrc
[[ -n "$_BASH_COMMON_LOADED" ]] && return
_BASH_COMMON_LOADED=1

# Source work-specific env (credentials, internal hostnames — not tracked in git)
[[ -f ~/.config/work.env ]] && source ~/.config/work.env

# PATH (common)
export PATH="$HOME/bin:/usr/local/bin:$PATH:$HOME/.local/bin:~/bin:~/.local/zed.app/bin"

# golang
export GOPATH=$HOME/go
export GOBIN=$HOME/go/bin
export PATH=$PATH:/usr/local/go/bin:$GOBIN

# claude
export CLAUDE_BASH_MAINTAIN_WORKING_DIR=1
export PATH="$HOME/.claude/local:$PATH"
export CLAUDE_CODE_THEME=light
alias clauded='claude --dangerously-skip-permissions'

# OS-specific
case "$(uname -s)" in
    Darwin)
        alias ls='ls -GH'
        alias top="top -o cpu"
        alias draw.io='/Applications/draw.io.app/Contents/MacOS/draw.io'
        export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"
        export PATH="/opt/homebrew/bin:$PATH"
        export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
        export DOTNET_ROOT=/usr/local/share/dotnet
        export PATH=$PATH:/usr/local/share/dotnet
        export PNPM_HOME="$HOME/Library/pnpm"
        case ":$PATH:" in
            *":$PNPM_HOME:"*) ;;
            *) export PATH="$PNPM_HOME:$PATH" ;;
        esac
        export TEXTRA_INSTALL="$HOME/.textra"
        export PATH="$TEXTRA_INSTALL/bin:$PATH"
        export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"
        ;;
    Linux)
        alias open="xdg-open"
        alias ls='ls --color'
        LS_COLORS='di=1;34:fi=0:ln=31:pi=5:so=5:bd=5:cd=5:or=31:mi=0;103:ex=35:*.rpm=90'
        export LS_COLORS
        if [[ -n "$SSH_CONNECTION" ]]; then
            if command -v keychain >/dev/null 2>&1; then
                _ssh_keys=()
                for _pub in "$HOME"/.ssh/*.pub; do
                    _key="${_pub%.pub}"
                    [[ -f "$_key" ]] && _ssh_keys+=("$_key")
                done
                [[ ${#_ssh_keys[@]} -gt 0 ]] && /usr/bin/keychain "${_ssh_keys[@]}"
                unset _pub _key _ssh_keys
            fi
            [[ -f $HOME/.keychain/$HOSTNAME-sh ]] && source $HOME/.keychain/$HOSTNAME-sh
        fi
        export PATH="$PATH:/opt/mssql-tools18/bin"
        export SQLCMDTRUSTED="yes"
        ;;
esac

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
# Only load nvm bash_completion if the bash-completion framework is already loaded
[ -n "$(type -t _completion_loader)" ] && [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# direnv
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook bash)"

# python
alias pip="pip3"
alias python=python3

# editor
export EDITOR="${EDITOR:-mg}"

# gerrit — set GERRIT_HOST in ~/.config/work.env
[[ -n "$GERRIT_HOST" ]] && alias gerrit="ssh -p 29418 $USER@$GERRIT_HOST gerrit"

# zed
alias zed='~/.local/zed.app/bin/zed --new'

# marktext
md() { marktext -n "$1" & }

# misc
alias sshr='ssh-keygen -R '
