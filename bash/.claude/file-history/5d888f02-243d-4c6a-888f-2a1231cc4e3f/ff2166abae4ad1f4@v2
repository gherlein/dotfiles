package config

import (
	"encoding/json"
	"fmt"
	"os"
	"path/filepath"
)

// ConfigFileName is the per-stack config file name.
const ConfigFileName = "config.json"

// CloudInitFileName is the per-stack cloud-init template file name.
const CloudInitFileName = "cloud-init.yaml"

// StackDir returns the directory for a named stack under the base folder.
func StackDir(baseFolder, name string) string {
	return filepath.Join(baseFolder, name)
}

// ConfigPath returns the config.json path for a named stack.
func ConfigPath(baseFolder, name string) string {
	return filepath.Join(baseFolder, name, ConfigFileName)
}

// CloudInitPath returns the cloud-init.yaml path for a named stack.
func CloudInitPath(baseFolder, name string) string {
	return filepath.Join(baseFolder, name, CloudInitFileName)
}

// Load reads, parses, and default-applies a config.json at path.
// It does not validate; callers decide when validation is required (e.g. create).
func Load(path string) (*Config, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		if os.IsNotExist(err) {
			return nil, fmt.Errorf("config file not found: create %s", path)
		}
		return nil, fmt.Errorf("reading config %s: %w", path, err)
	}
	var cfg Config
	if err := json.Unmarshal(data, &cfg); err != nil {
		return nil, fmt.Errorf("parsing config %s: %w", path, err)
	}
	cfg.ApplyDefaults()
	return &cfg, nil
}

// Save writes the config back to path as indented JSON, preserving input
// sections and persisting state sections. The parent directory is created if
// needed.
func Save(path string, cfg *Config) error {
	if err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {
		return fmt.Errorf("creating stack dir: %w", err)
	}
	data, err := json.MarshalIndent(cfg, "", "  ")
	if err != nil {
		return fmt.Errorf("encoding config: %w", err)
	}
	data = append(data, '\n')
	if err := os.WriteFile(path, data, 0o644); err != nil {
		return fmt.Errorf("writing config %s: %w", path, err)
	}
	return nil
}
