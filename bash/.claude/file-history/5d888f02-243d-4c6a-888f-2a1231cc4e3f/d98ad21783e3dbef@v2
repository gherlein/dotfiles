#cloud-config
# Dev template: base tooling plus a developer toolbelt.
users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ${SSH_PUBLIC_KEY}
package_update: true
packages:
  - curl
  - wget
  - vim
  - htop
  - git
  - ca-certificates
  - build-essential
  - ripgrep
  - tmux
  - fzf
  - jq
