#cloud-config
# Go dev template: Go toolchain plus gopls and delve.
users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ${SSH_PUBLIC_KEY}
package_update: true
packages:
  - curl
  - git
  - ca-certificates
  - build-essential
runcmd:
  - curl -LO https://go.dev/dl/go1.23.0.linux-amd64.tar.gz
  - rm -rf /usr/local/go && tar -C /usr/local -xzf go1.23.0.linux-amd64.tar.gz
  - rm go1.23.0.linux-amd64.tar.gz
  - echo 'export PATH=$PATH:/usr/local/go/bin:$HOME/go/bin' >> /home/ubuntu/.bashrc
  - sudo -u ubuntu bash -lc '/usr/local/go/bin/go install golang.org/x/tools/gopls@latest'
  - sudo -u ubuntu bash -lc '/usr/local/go/bin/go install github.com/go-delve/delve/cmd/dlv@latest'
