package config

import (
	"encoding/json"
	"os"
	"path/filepath"
	"testing"
)

func TestLoadMinimalAppliesDefaults(t *testing.T) {
	dir := t.TempDir()
	path := filepath.Join(dir, "config.json")
	minimal := `{"vm":{"name":"devbox","users":[{"username":"ubuntu","github_username":"alice"}]}}`
	if err := os.WriteFile(path, []byte(minimal), 0o644); err != nil {
		t.Fatal(err)
	}

	cfg, err := Load(path)
	if err != nil {
		t.Fatalf("Load: %v", err)
	}
	vm := cfg.VM
	if vm.CPUs != DefaultCPUs {
		t.Errorf("cpus = %d, want %d", vm.CPUs, DefaultCPUs)
	}
	if vm.Memory != DefaultMemory {
		t.Errorf("memory = %q, want %q", vm.Memory, DefaultMemory)
	}
	if vm.Disk != DefaultDisk {
		t.Errorf("disk = %q, want %q", vm.Disk, DefaultDisk)
	}
	if vm.Image != DefaultImage {
		t.Errorf("image = %q, want %q", vm.Image, DefaultImage)
	}
	if vm.Region != DefaultRegion {
		t.Errorf("region = %q, want %q", vm.Region, DefaultRegion)
	}
	if vm.InstanceType != DefaultInstanceType {
		t.Errorf("instance_type = %q, want %q", vm.InstanceType, DefaultInstanceType)
	}
}

func TestLoadNotFound(t *testing.T) {
	_, err := Load(filepath.Join(t.TempDir(), "missing.json"))
	if err == nil {
		t.Fatal("expected error for missing file")
	}
}

func TestDNSDefaults(t *testing.T) {
	cfg := &Config{
		VM:  &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}},
		DNS: &DNSConfig{Domain: "example.com"},
	}
	cfg.ApplyDefaults()
	if cfg.DNS.TTL != DefaultTTL {
		t.Errorf("ttl = %d, want %d", cfg.DNS.TTL, DefaultTTL)
	}
	if cfg.DNS.Hostname != "web" {
		t.Errorf("hostname = %q, want vm.name 'web'", cfg.DNS.Hostname)
	}
}

func TestSaveRoundTripPreservesInput(t *testing.T) {
	dir := t.TempDir()
	path := filepath.Join(dir, "config.json")
	cfg := &Config{
		VM: &VMConfig{
			Name:   "web-server",
			CPUs:   4,
			Memory: "4G",
			Mounts: []Mount{{Source: "/host/code", Target: "/home/ubuntu/code"}},
			Users:  []User{{Username: "ubuntu", GitHubUsername: "alice"}},
		},
		DNS:   &DNSConfig{Hostname: "web", Domain: "example.com", TTL: 300},
		Local: &LocalState{IP: "192.168.122.5", Network: "default"},
	}
	if err := Save(path, cfg); err != nil {
		t.Fatalf("Save: %v", err)
	}
	got, err := Load(path)
	if err != nil {
		t.Fatalf("Load: %v", err)
	}
	if got.VM.Name != "web-server" || got.VM.CPUs != 4 || got.VM.Memory != "4G" {
		t.Errorf("vm input not preserved: %+v", got.VM)
	}
	if got.Local == nil || got.Local.IP != "192.168.122.5" {
		t.Errorf("local state not persisted: %+v", got.Local)
	}
	if len(got.VM.Mounts) != 1 || got.VM.Mounts[0].Target != "/home/ubuntu/code" {
		t.Errorf("mounts not preserved: %+v", got.VM.Mounts)
	}
}

func TestSaveOmitsEmptyStateSections(t *testing.T) {
	dir := t.TempDir()
	path := filepath.Join(dir, "config.json")
	cfg := &Config{VM: &VMConfig{Name: "x", Users: []User{{Username: "ubuntu", GitHubUsername: "a"}}}}
	if err := Save(path, cfg); err != nil {
		t.Fatal(err)
	}
	data, _ := os.ReadFile(path)
	var raw map[string]json.RawMessage
	if err := json.Unmarshal(data, &raw); err != nil {
		t.Fatal(err)
	}
	for _, k := range []string{"local", "aws", "do", "dns"} {
		if _, ok := raw[k]; ok {
			t.Errorf("empty section %q should be omitted", k)
		}
	}
}

func TestValidate(t *testing.T) {
	tests := []struct {
		name    string
		cfg     *Config
		wantErr bool
	}{
		{"valid", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}}}, false},
		{"no vm", &Config{}, true},
		{"no name", &Config{VM: &VMConfig{Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}}}, true},
		{"no users", &Config{VM: &VMConfig{Name: "web"}}, true},
		{"bad username", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "1bad", GitHubUsername: "alice"}}}}, true},
		{"username metachar", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "a;b", GitHubUsername: "alice"}}}}, true},
		{"bad github", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "-bad"}}}}, true},
		{"dup users", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}, {Username: "ubuntu", GitHubUsername: "bob"}}}}, true},
		{"cname no domain", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}}, DNS: &DNSConfig{CNAMEAliases: []string{"www"}}}, true},
		{"apex no domain", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}}, DNS: &DNSConfig{IsApexDomain: true}}, true},
		{"cname with domain", &Config{VM: &VMConfig{Name: "web", Users: []User{{Username: "ubuntu", GitHubUsername: "alice"}}}, DNS: &DNSConfig{Domain: "example.com", CNAMEAliases: []string{"www"}}}, false},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := tt.cfg.Validate()
			if (err != nil) != tt.wantErr {
				t.Errorf("Validate() err = %v, wantErr %v", err, tt.wantErr)
			}
		})
	}
}

func TestValidateName(t *testing.T) {
	for _, ok := range []string{"web", "web-server", "devbox", "web-server-v2", "a_b"} {
		if err := ValidateName(ok); err != nil {
			t.Errorf("ValidateName(%q) unexpected error: %v", ok, err)
		}
	}
	for _, bad := range []string{"", "1web", "Web", "web;rm", "web server", "../etc"} {
		if err := ValidateName(bad); err == nil {
			t.Errorf("ValidateName(%q) expected error", bad)
		}
	}
}
