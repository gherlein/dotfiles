// Package provider defines the common interface implemented by each VM backend
// (libvirt, aws, digitalocean) and shared provider types.
package provider

import (
	"context"
	"time"

	"github.com/gherlein/govirt/internal/config"
)

// VMProvider is the lifecycle contract every backend implements.
type VMProvider interface {
	Name() string
	Create(ctx context.Context, cfg *config.Config, cloudInitPath string) error
	Delete(ctx context.Context, cfg *config.Config) error
	Status(ctx context.Context, cfg *config.Config) (*VMStatus, error)
	List(ctx context.Context) ([]VMStatus, error)
	SSH(ctx context.Context, cfg *config.Config) error
	Stop(ctx context.Context, cfg *config.Config) error
	Start(ctx context.Context, cfg *config.Config) error
}

// VMStatus is the normalized status reported across providers.
type VMStatus struct {
	Name      string
	State     string
	IP        string
	Provider  string
	CreatedAt time.Time
}

// DNSSwapper is implemented by providers that support in-place DNS record
// updates (aws, digitalocean).
type DNSSwapper interface {
	SwapDNS(ctx context.Context, cfg *config.Config) error
}
