// Package libvirt implements the local VM provider backed by libvirt/KVM. All
// hypervisor interaction shells out to virsh, virt-install, and qemu-img via an
// explicit-argument Runner (no shell), so VM names and paths cannot inject
// commands.
package libvirt

import (
	"context"
	"fmt"
	"io"
	"os"
	"os/exec"
	"path/filepath"
	"strconv"
	"strings"
	"syscall"
	"time"

	"github.com/gherlein/govirt/internal/cloudinit"
	"github.com/gherlein/govirt/internal/config"
	"github.com/gherlein/govirt/internal/provider"
)

// DefaultPoolDir is the libvirt default storage pool directory.
const DefaultPoolDir = "/var/lib/libvirt/images"

// DefaultNetwork is the libvirt network VMs attach to.
const DefaultNetwork = "default"

// ImageEnsurer resolves an image shorthand to a local cached base image path.
// *images.Manager satisfies it.
type ImageEnsurer interface {
	Ensure(ctx context.Context, image string) (string, error)
}

// Provider is the libvirt VMProvider implementation.
type Provider struct {
	Runner  Runner
	Images  ImageEnsurer
	PoolDir string
	Verbose bool
	Out     io.Writer
}

// New returns a Provider with production defaults.
func New(images ImageEnsurer) *Provider {
	return &Provider{
		Runner:  execRunner{},
		Images:  images,
		PoolDir: DefaultPoolDir,
		Out:     os.Stderr,
	}
}

// Name implements provider.VMProvider.
func (p *Provider) Name() string { return "local" }

func (p *Provider) out() io.Writer {
	if p.Out != nil {
		return p.Out
	}
	return os.Stderr
}

func (p *Provider) diskPath(name string) string {
	return filepath.Join(p.PoolDir, name+".qcow2")
}

func (p *Provider) isoPath(name string) string {
	return filepath.Join(p.PoolDir, name+"-cloud-init.iso")
}

// Create provisions a local VM from the processed cloud-init document at
// cloudInitPath.
func (p *Provider) Create(ctx context.Context, cfg *config.Config, cloudInitPath string) error {
	if cfg.VM == nil {
		return fmt.Errorf("config missing vm section")
	}
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return err
	}
	if err := p.checkPrereqs(); err != nil {
		return err
	}
	if p.exists(ctx, name) {
		return fmt.Errorf("VM already exists: destroy first with 'govirt destroy %s'", name)
	}

	base, err := p.Images.Ensure(ctx, cfg.VM.Image)
	if err != nil {
		return err
	}

	disk := p.diskPath(name)
	if err := p.createDisk(ctx, base, disk, cfg.VM.Disk); err != nil {
		return err
	}

	userData, err := os.ReadFile(cloudInitPath)
	if err != nil {
		return fmt.Errorf("reading processed cloud-init: %w", err)
	}
	iso := p.isoPath(name)
	tool := detectISOTool()
	if err := buildISO(ctx, p.Runner, tool, name, string(userData), iso); err != nil {
		return err
	}

	memMB, err := parseMemoryMB(cfg.VM.Memory)
	if err != nil {
		return err
	}
	variant, known := mapOSVariant(cfg.VM.Image)
	if !known {
		fmt.Fprintf(p.out(), "warning: unknown image %q not in osinfo database; falling back to os-variant ubuntu20.04\n", cfg.VM.Image)
	}
	useVirtiofs := kernelSupportsVirtiofs(kernelRelease())
	if len(cfg.VM.Mounts) > 0 && !useVirtiofs {
		fmt.Fprintf(p.out(), "warning: virtiofs unavailable (host kernel < 5.4); falling back to 9p\n")
	}
	args := buildVirtInstallArgs(name, memMB, cfg.VM.CPUs, disk, iso, variant, DefaultNetwork, cfg.VM.Mounts, useVirtiofs)
	if err := p.Runner.Run(ctx, "virt-install", args...); err != nil {
		return err
	}

	ip := pollIP(ctx, p.Runner, name, DefaultNetwork, defaultIPPoll)
	if ip == "" {
		fmt.Fprintf(p.out(), "warning: VM started but no IP assigned after %s: check libvirt network with 'virsh net-list'\n", defaultIPPoll.timeout)
	}

	cfg.Local = &config.LocalState{
		IP:           ip,
		DomainName:   name,
		DiskPath:     disk,
		CloudInitISO: iso,
		Network:      DefaultNetwork,
	}
	return nil
}

// createDisk builds a copy-on-write overlay over the cached base image and
// resizes it to the requested size.
func (p *Provider) createDisk(ctx context.Context, base, disk, size string) error {
	if err := p.Runner.Run(ctx, "qemu-img", "create", "-f", "qcow2",
		"-b", base, "-F", "qcow2", disk, size); err != nil {
		return fmt.Errorf("creating VM disk: %w", err)
	}
	if err := p.Runner.Run(ctx, "qemu-img", "resize", disk, size); err != nil {
		return fmt.Errorf("resizing VM disk: %w", err)
	}
	return nil
}

// Delete force-stops and removes the VM, its storage, and the cloud-init ISO.
func (p *Provider) Delete(ctx context.Context, cfg *config.Config) error {
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return err
	}
	// Ignore error: the domain may already be stopped.
	_ = p.Runner.Run(ctx, "virsh", "destroy", name)
	if err := p.Runner.Run(ctx, "virsh", "undefine", name, "--remove-all-storage"); err != nil {
		return err
	}
	if cfg.Local != nil && cfg.Local.CloudInitISO != "" {
		os.Remove(cfg.Local.CloudInitISO)
	} else {
		os.Remove(p.isoPath(name))
	}
	cfg.Local = nil
	return nil
}

// Stop performs a graceful ACPI shutdown and waits for the domain to stop.
func (p *Provider) Stop(ctx context.Context, cfg *config.Config) error {
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return err
	}
	if err := p.Runner.Run(ctx, "virsh", "shutdown", name); err != nil {
		return err
	}
	deadline := time.Now().Add(30 * time.Second)
	for {
		if p.domState(ctx, name) == "shut off" {
			return nil
		}
		if time.Now().After(deadline) {
			return fmt.Errorf("VM %s did not stop within 30s", name)
		}
		select {
		case <-ctx.Done():
			return ctx.Err()
		case <-time.After(2 * time.Second):
		}
	}
}

// Start boots the VM and refreshes its IP in state.
func (p *Provider) Start(ctx context.Context, cfg *config.Config) error {
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return err
	}
	if err := p.Runner.Run(ctx, "virsh", "start", name); err != nil {
		return err
	}
	network := DefaultNetwork
	if cfg.Local != nil && cfg.Local.Network != "" {
		network = cfg.Local.Network
	}
	ip := pollIP(ctx, p.Runner, name, network, defaultIPPoll)
	if ip != "" {
		if cfg.Local == nil {
			cfg.Local = &config.LocalState{Network: network, DomainName: name}
		}
		cfg.Local.IP = ip
	}
	return nil
}

// Status reports the VM state and current IP.
func (p *Provider) Status(ctx context.Context, cfg *config.Config) (*provider.VMStatus, error) {
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return nil, err
	}
	state := p.domState(ctx, name)
	if state == "" {
		return nil, fmt.Errorf("VM not found: check 'govirt list' for available VMs")
	}
	network := DefaultNetwork
	if cfg.Local != nil && cfg.Local.Network != "" {
		network = cfg.Local.Network
	}
	ip := ""
	if state == "running" {
		ip = lookupIP(ctx, p.Runner, name, network)
	}
	return &provider.VMStatus{Name: name, State: state, IP: ip, Provider: p.Name()}, nil
}

// List returns all libvirt domains.
func (p *Provider) List(ctx context.Context) ([]provider.VMStatus, error) {
	out, err := p.Runner.Output(ctx, "virsh", "list", "--all")
	if err != nil {
		return nil, err
	}
	var result []provider.VMStatus
	for _, d := range parseList(string(out)) {
		st := provider.VMStatus{Name: d.Name, State: d.State, Provider: p.Name()}
		if d.State == "running" {
			st.IP = lookupIP(ctx, p.Runner, d.Name, DefaultNetwork)
		}
		result = append(result, st)
	}
	return result, nil
}

// SSH replaces the current process with an interactive ssh session to the VM.
func (p *Provider) SSH(ctx context.Context, cfg *config.Config) error {
	name := cfg.VM.Name
	if err := config.ValidateName(name); err != nil {
		return err
	}
	if len(cfg.VM.Users) == 0 {
		return fmt.Errorf("no users defined for %s", name)
	}
	ip := ""
	if cfg.Local != nil {
		ip = cfg.Local.IP
	}
	if ip == "" {
		ip = lookupIP(ctx, p.Runner, name, DefaultNetwork)
	}
	if ip == "" {
		return fmt.Errorf("no IP for %s: check 'govirt status %s'", name, name)
	}
	user := cfg.VM.Users[0].Username
	sshPath, err := exec.LookPath("ssh")
	if err != nil {
		return fmt.Errorf("ssh not found: %w", err)
	}
	argv := []string{"ssh", "-o", "StrictHostKeyChecking=no", user + "@" + ip}
	return syscall.Exec(sshPath, argv, os.Environ())
}

func (p *Provider) exists(ctx context.Context, name string) bool {
	return p.domState(ctx, name) != ""
}

func (p *Provider) domState(ctx context.Context, name string) string {
	out, err := p.Runner.Output(ctx, "virsh", "dominfo", name)
	if err != nil {
		return ""
	}
	return parseDominfoState(string(out))
}

// checkPrereqs verifies the local toolchain and /dev/kvm access.
func (p *Provider) checkPrereqs() error {
	required := map[string]string{
		"virsh":        "virsh not found: install libvirt (sudo apt install libvirt-daemon-system)",
		"virt-install": "virt-install not found: install virtinst (sudo apt install virtinst)",
		"qemu-img":     "qemu-img not found: install qemu-utils (sudo apt install qemu-utils)",
	}
	for bin, msg := range required {
		if _, err := exec.LookPath(bin); err != nil {
			return fmt.Errorf("%s", msg)
		}
	}
	if detectISOTool() == isoNone {
		return fmt.Errorf("neither cloud-localds nor genisoimage found: install cloud-image-utils or genisoimage")
	}
	if _, err := os.Stat("/dev/kvm"); err != nil {
		return fmt.Errorf("/dev/kvm not accessible: check that the current user is in the 'kvm' group")
	}
	return nil
}

// detectISOTool returns the preferred available NoCloud ISO generator.
func detectISOTool() isoTool {
	if _, err := exec.LookPath("cloud-localds"); err == nil {
		return isoCloudLocalds
	}
	if _, err := exec.LookPath("genisoimage"); err == nil {
		return isoGenisoimage
	}
	return isoNone
}

// parseMemoryMB converts a memory string ("2G", "512M", "1024") to megabytes.
func parseMemoryMB(mem string) (int, error) {
	s := strings.TrimSpace(mem)
	if s == "" {
		return 0, fmt.Errorf("empty memory value")
	}
	mult := 1
	switch last := s[len(s)-1]; last {
	case 'G', 'g':
		mult = 1024
		s = s[:len(s)-1]
	case 'M', 'm':
		mult = 1
		s = s[:len(s)-1]
	}
	n, err := strconv.Atoi(strings.TrimSpace(s))
	if err != nil {
		return 0, fmt.Errorf("invalid memory value %q: %w", mem, err)
	}
	return n * mult, nil
}

// mapOSVariant maps an image shorthand to a libvirt os-variant. The second
// return reports whether the shorthand was recognized; unknown values fall back
// to ubuntu20.04 and known=false so the caller can warn.
func mapOSVariant(image string) (variant string, known bool) {
	switch image {
	case "24.04":
		return "ubuntu24.04", true
	case "22.04":
		return "ubuntu22.04", true
	case "20.04":
		return "ubuntu20.04", true
	default:
		return "ubuntu20.04", false
	}
}

// kernelRelease returns the running kernel release string, or "" if unreadable.
func kernelRelease() string {
	data, err := os.ReadFile("/proc/sys/kernel/osrelease")
	if err != nil {
		return ""
	}
	return strings.TrimSpace(string(data))
}

// kernelSupportsVirtiofs reports whether the kernel release is >= 5.4, the
// minimum for virtiofs. An unparseable release defaults to true (assume modern).
func kernelSupportsVirtiofs(release string) bool {
	if release == "" {
		return true
	}
	parts := strings.SplitN(release, ".", 3)
	if len(parts) < 2 {
		return true
	}
	major, err1 := strconv.Atoi(parts[0])
	minor, err2 := strconv.Atoi(parts[1])
	if err1 != nil || err2 != nil {
		return true
	}
	if major != 5 {
		return major > 5
	}
	return minor >= 4
}

// buildVirtInstallArgs assembles the virt-install argument slice.
func buildVirtInstallArgs(name string, memMB, cpus int, disk, iso, variant, network string, mounts []config.Mount, useVirtiofs bool) []string {
	if cpus <= 0 {
		cpus = config.DefaultCPUs
	}
	args := []string{
		"--name", name,
		"--memory", strconv.Itoa(memMB),
		"--vcpus", strconv.Itoa(cpus),
		"--disk", "path=" + disk + ",format=qcow2",
		"--disk", "path=" + iso + ",device=cdrom",
		"--os-variant", variant,
		"--network", "network=" + network,
		"--graphics", "none",
		"--noautoconsole",
		"--import",
	}
	for _, m := range mounts {
		tag := cloudinit.MountTag(m.Target)
		driver := "virtiofs"
		if !useVirtiofs {
			driver = "9p"
		}
		args = append(args, "--filesystem",
			fmt.Sprintf("source=%s,target=%s,driver.type=%s", m.Source, tag, driver))
	}
	return args
}

var _ provider.VMProvider = (*Provider)(nil)
