#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 <org> <repo-name>"
  echo ""
  echo "  org        GitHub organization name"
  echo "  repo-name  Name of the new repository"
  exit 1
}

if [[ $# -ne 2 ]]; then
  usage
fi

ORG="$1"
REPO="$2"

if ! gh auth status &>/dev/null; then
  gh auth login
fi

if ! gh api "orgs/${ORG}" &>/dev/null; then
  echo "Error: GitHub org '${ORG}' not found or you do not have access"
  exit 1
fi

gh repo create "${ORG}/${REPO}" --private

git init

# Commit only if there is something to commit; an empty commit would abort
# under `set -e` and skip the remote/push steps below.
git add .
if ! git diff --cached --quiet; then
  git commit -m "Initial commit"
fi

# Push the branch we are actually on rather than forcing a rename to main,
# which would clobber an existing feature branch.
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [[ "${BRANCH}" == "master" ]]; then
  git branch -M main
  BRANCH="main"
fi

# Add the remote idempotently: gpnew may run in a repo that already has one.
REMOTE_URL="git@github.com:${ORG}/${REPO}.git"
if git remote get-url origin &>/dev/null; then
  git remote set-url origin "${REMOTE_URL}"
else
  git remote add origin "${REMOTE_URL}"
fi

git push -u origin "${BRANCH}"

gh repo edit "${ORG}/${REPO}" --default-branch "${BRANCH}"
