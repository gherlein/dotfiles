#!/bin/bash

# Get the current git branch name (works on older git and detached HEAD)
branch_name=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# Check if we're in a git repository
if [ -z "$branch_name" ] || [ "$branch_name" = "HEAD" ]; then
    echo "Error: Not in a git repository or no branch checked out"
    exit 1
fi

# Get commit message from command line argument or use default
if [ -z "$1" ]; then
    commit_message="interim commit"
else
    commit_message="$1"
fi

# Commit local work first so the tree is clean for the rebase below
# (git pull --rebase refuses to run with uncommitted changes).
git add .
git commit -am "$commit_message"

# Bring in and rebase onto the latest remote before pushing, so a remote that
# has advanced doesn't reject the push. Skip when no upstream exists yet (first
# push); the 'git push -u' below establishes it.
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' &>/dev/null; then
    if ! git pull --rebase; then
        echo "Error: rebase failed — resolve conflicts, then push."
        exit 1
    fi
fi

# Push. If the branch has no upstream yet (first push of a new branch), create
# it explicitly against origin -- a bare `git push` fails on a branch with no
# upstream. Otherwise push to the already-tracked upstream.
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' &>/dev/null; then
    git push
else
    git push --set-upstream origin "$branch_name"
fi
