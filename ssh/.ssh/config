# Include host-specific config that is NOT tracked in git
# Put sensitive hosts (IPs, internal infra) in ~/.ssh/config.local
Include ~/.ssh/config.local

Host github.com
  HostName ssh.github.com
  Port 443

Host *
  IgnoreUnknown UseKeychain
  UseKeychain yes
  AddKeysToAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 5
  IPQoS throughput
  TCPKeepAlive yes
