{
    "$schema": "https://opencode.ai/config.json",
    "model": "ollama/qwen3.5:35b-a3b-q4_k_m",
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://localhost:11434/v1"
            },
            "models": {
                "qwen3.5:35b-a3b-q4_k_m": {
                    "name": "Qwen3.5 35B MoE (default)",
                    "tools": true
                },
                "qwen2.5-coder:32b": {
                    "name": "Qwen2.5 Coder 32B (coding)",
                    "tools": true
                },
                "qwen2.5-coder:7b": {
                    "name": "Qwen2.5 Coder 7B (fast)",
                    "tools": true
                }
            }
        }
    },
    "lsp": {
        "go": {
            "command": [
                "gopls"
            ],
            "extensions": [
                ".go"
            ]
        }
    },
    "compaction": {
        "strategy": "auto"
    },
    "autoupdate": true,
    "permission": {
        "bash": {
            "*": "allow",
            "rm -rf *": "ask",
            "sudo *": "ask",
            "dd *": "deny"
        },
        "external_directory": {
            "~/**": "allow"
        }
    },
    "mcp": {
        "codebase-memory-mcp": {
            "enabled": true,
            "type": "local",
            "command": [
                "/home/gherlein/.local/bin/codebase-memory-mcp"
            ]
        }
    }
}
